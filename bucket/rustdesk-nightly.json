    "checkver": {
        "github": "https://api.github.com/repos/rustdesk/rustdesk/releases/tags/nightly",
        "script": [
            "$api = $page | ConvertFrom-Json",
            "foreach ($name in $api.assets.name) { if ($name -clike '*-x86_64.exe') { $asset = $name; break } }",
            "$result = (Get-Date $api.assets[0].updated_at -UFormat %s), $asset -join ' '",
            "$output = @{'result' = \"$result\"} | ConvertTo-Json -Compress",
            "Write-Output $output"
        ],
        "jsonpath": "$.result",
        "regex": "\\A(\\d+) rustdesk-(?<release>[\\d.-]+)-x86_64.exe\\Z"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gh-proxy.org/https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-$matchRelease-x86_64.exe#/RustDesk.exe"
            },
            "32bit": {
                "url": "https://gh-proxy.org/https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-$matchRelease-x86-sciter.exe#/RustDesk.exe"
