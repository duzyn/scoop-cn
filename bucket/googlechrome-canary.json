            "hash": "d2f9cecfa78eeb75a4fa87427f45566057f7de542b06a58c2c4f8d47754a9896"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ackobo5tehtmw35oxw3mrl55dcga_151.0.7897.1/151.0.7897.1_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "52b962a4c72cc48b6a61cca368a85eefd66b80936acd8f2e01c4993518370af9"
