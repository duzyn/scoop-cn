            "hash": "af7719262c39b307199f4e840ce721e2de5992f91e923c5f7c9ac36bb391cce1"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/c23zkqqtk7qw453p6lyfvpp35m_150.0.7859.0/150.0.7859.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "169c680891726be761b21a3976380d62435c84fa96bef02c065047f09836f0ca"
