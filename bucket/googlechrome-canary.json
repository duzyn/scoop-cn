        "arm64": {
            "url": "https://dl.google.com/release2/chrome/msqyzo6g5eb7gaoinlbhsccsbq_148.0.7770.0/148.0.7770.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "b129b6a90d12dd831708c1f008636888ddfb7b98148c0ea03dc9354b64397865"
