        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/aclmsxitvpqjq3fsjlpwrk7gpmaa_150.0.7851.0/150.0.7851.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "4525dcb39bbce0e97de443c7bd034397b65b7c761a059b67c6da5a0642cd34ee"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/aywfzavwd7ugozo7tpkrosa33u_150.0.7851.0/150.0.7851.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "310a32a5a370a4a704e9c6a5cdda45671d65ec34ed992c4039d6250cfd974ba2"
