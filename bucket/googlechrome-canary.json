        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acxsdqbzbfgeggilocgg577kyfka_147.0.7719.0/147.0.7719.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "967890ad106e8680e270908189b0b9f3ba4eb0c63f12526edb39dc1ccf2d0c52"
