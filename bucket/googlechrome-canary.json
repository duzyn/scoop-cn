            "hash": "68c23bf9fe6445fa5527360be9caf28351bed7813c38f3b655af09d80b51e7ad"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acci7gg6avpsmm6m65w2jkgoqcsq_148.0.7732.0/148.0.7732.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6c90c421ebac759451674801a826ebae3f3bad871323f9bb0e78a6edc67c82f6"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acmwcg66msw7ryagnrvdkclxkxoa_148.0.7732.0/148.0.7732.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "1929a4103e721a8d148efc87070722237122ea88da0fd84e93f6d78888e19ddc"
        }
