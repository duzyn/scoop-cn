        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acddpkangqi2ethkcox3ac35usna_149.0.7796.0/149.0.7796.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "64ca7e68f03f5dfc293f9f2471379aee13befdf6ccf2698b45a97c44a6b22604"
