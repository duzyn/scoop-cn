        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acfeufidro7mfaihffvswqcnyvfq_148.0.7745.0/148.0.7745.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "a42093477bdfb58b1bcff8ce2583a398a7c736e9b0bbc9edb906b93133f084c3"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/m2kphbyheihpgxzwgl3ahldwem_148.0.7745.0/148.0.7745.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "9d8d5d299045ea2675807a08dd4922b6cc6f35e6c7659774c70a2e93f3aec050"
