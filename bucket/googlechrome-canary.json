        "arm64": {
            "url": "https://dl.google.com/release2/chrome/mazgdr3ejhm2cfd3dzhz5n3gfu_148.0.7774.0/148.0.7774.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6969919b04425b0f67f4357546c55beac23e540f63d3e6f6aadbbc082382853f"
