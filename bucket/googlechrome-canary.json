            "hash": "5fac777eaf7a750c0fb964f4eb1723961ed92d323d41e57db008b648f659227a"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/adl3voijitxesrtb7mqibwv423ca_150.0.7840.0/150.0.7840.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "00263fdadeb586aaa5da5bf384aaa354e43bb3085463ff43555f06e00b408c6a"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adrorfdxalxajbw3g2b7ghzl2dda_150.0.7840.0/150.0.7840.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d44fb80a6cb849f56ba150ea9fca671de8fd6dafca36a8febea8e2a95f55f2bf"
