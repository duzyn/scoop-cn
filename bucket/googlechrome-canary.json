        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ocskk7d4mhbcdy3r35cpurnlc4_150.0.7871.0/150.0.7871.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "40524f0d618f18a610a825a730c988c9a403b79976152fdb4497d93b99018af4"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/achkdscx6hiqdioprc6xrdmzn4xa_150.0.7871.0/150.0.7871.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6db1831a0cab725f1c1a91014d49227a9f1a0e71d2207f6bc2bd0e5d61e34a50"
