            "hash": "e4f3ff2ad8680daaeca43371d5867b1a23b1dbc6a0e0189018547f4704797b65"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/b76ivqa6c6npb4ohlitrguzea4_148.0.7748.0/148.0.7748.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6b9e018d47b706155ca3e4dcf87a5eac8c8d1cf7532a1071a1fd88ed18a61a22"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adqhaesngkwaogzcckqkhwnjtbcq_148.0.7748.0/148.0.7748.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d3e6cef6653280fb5621122590129cb159ac1cdfc3db1ea60ac3ab4fb073099e"
