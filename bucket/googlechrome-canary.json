            "hash": "2eb0fed996eca0ffa1df5c973fe22167b131c9e4ad6adcdd42449d5bc6eacbb6"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acfnzity2iact3ojaplydztwr3xq_148.0.7751.0/148.0.7751.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "dcc9ce089268d1f3935a651dd0ebaabc2bb257286738d028c52641de3fd31d25"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/c7zd5urhlhzbdyxy3pgx2v4zpy_148.0.7751.0/148.0.7751.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "548566c768bc0af06be5e11018d543e32619c318c71fa1dcd48b4606e8d8e3d7"
