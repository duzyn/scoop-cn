            "hash": "23839d6f98712fba364a66f9bd2af9292accee9cf2ad0f8313420cf42149c8db"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/adcwdoodhzbq7ex43mti46iuhlua_150.0.7847.0/150.0.7847.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d3d960c7652ab0f0ab1f3c232ad3db0039effb78d3010e48f0c2b1480b0ecc82"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ewppkycpoyhhnjhvxevgy7tppq_150.0.7847.0/150.0.7847.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "503c8169c8d6c11986657d87f10b79f8e353d0eab4cc8a5ed4d4fd2e43381a58"
