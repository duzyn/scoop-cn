            "hash": "570a242200af23ddc77dba0f1140941144e098323b8110c33fe467bef119fddd"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/dyc6la42tzvfewdfb7yhzn7rwi_151.0.7896.0/151.0.7896.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "218cdbd9addd9f28470ffcd00999c1025c03b4a273295710723175e4dc1d9c72"
