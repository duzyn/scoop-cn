            "hash": "37c2bb690272a16abfdac4b9fc951bdfe805e27335e06825893fe18ea9f153e0"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acvqj7iszamkdblervdlblgf6xka_148.0.7737.0/148.0.7737.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6993642b095aa61fcf36216221e0b0fd9f53ecae40922ee347a0faa8be8dbf6d"
