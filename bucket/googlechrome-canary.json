            "hash": "68f62920dffb3db6c2910833aa970592fe810e2adf37642d0580fbcc6c989e59"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/hgkh3azbo4tbstryusmdyklsqi_151.0.7920.0/151.0.7920.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "ab9692e97fc96dd4902960a57dda146823290fa3779f12109c17b86263583bca"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/mz4dzpmgvqlvlfhs6a3ztd2eee_151.0.7920.0/151.0.7920.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "f824cd8287f75b55b31fff3b07dd6b167f63d9ba19c8e81bf32f819abc4b3ca2"
