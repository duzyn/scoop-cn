        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acjsyh7arhm7qdpnbsnaojo4tbpa_148.0.7765.0/148.0.7765.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "ba26fe1167fa0a3079f3966b973312896cd9b112081248d16878cef0ded590f6"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/anuibl7a42qq3hv623eyz2pcpm_148.0.7765.0/148.0.7765.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "c37e6e2faf41a6f9ee3fc47ec9926013856ff23449cbc8ca1747e5fba9c31f9e"
