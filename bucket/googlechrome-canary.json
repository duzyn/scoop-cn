            "hash": "cb35656ba2eb63a29d69b1888039ed8250806adb3068916ef01d59a327c67c8d"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ljuen5qkkwtar3sb6hb6kjnfxe_149.0.7817.0/149.0.7817.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "42d62486da990827419794b72bed17857511ab2f8fcfef8c3ee7587e1eb55608"
