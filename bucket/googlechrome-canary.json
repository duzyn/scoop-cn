            "hash": "55782b5cc392c5b5f74becdb9f2a657081113846dad4fd033650eae65eded64f"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/advk3mffr22bhjxcphjnuh7jqn4a_150.0.7868.0/150.0.7868.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "c8cd7b6051915c7cee73b58f0ecfaa2f48f894a4010926a7a21e780279b3088b"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/jr6eoj2rfohwpjqf4wsdoveanu_150.0.7868.0/150.0.7868.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "95e327641eefcfeae072c7ce3a0ece18ef715faef753aeeeedf2a8b7290db1b1"
