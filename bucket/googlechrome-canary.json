            "hash": "b251b384296661c2094ef7ee5873c48f14e16d4485caaf4bb3e60c76f3743b22"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/iyh5x4glowx6ndc7jwo4q4y5mi_151.0.7902.0/151.0.7902.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "920e64207586df384ad53b927f513c29a1fe9b5b1985e508163bce3ce43dc0f0"
