            "hash": "0431979268588dfdef0f73b883db080ff9864451e73bbb9d7611b379ea94444f"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/pqm4p24x43jmehgire5zxpptr4_150.0.7864.0/150.0.7864.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "0187f683df66c1f87813b985b13e6e41fa6b5a6cca02d2ab02e846c4b532ff87"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/n7qllkczl4gv666tezvncp6yme_150.0.7864.0/150.0.7864.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "db16eff9cd6aa9435d94a7db18eaebff41f61c8f602d7be512415c14a349a4c1"
