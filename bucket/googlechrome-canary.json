            "hash": "12abeff64053c782c8157a5a20df163e8e4bdcb01eae4daffba20749bea650f5"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/fuv25eymbek2g5ndtjc47dvmcm_150.0.7838.0/150.0.7838.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "406374b669a86d7f7ec08093cfe2dfee16102a310a6f50f17bf1a415be554765"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/jpeuqoizmyo4opv33r77vnmsoe_150.0.7838.0/150.0.7838.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "b314067229df9dfd852a96fe64ae2a2c7b2911c6c850556000276555d742af01"
