            "hash": "bea9a515289277d906a6dd8721f274f61b9c70cba467fd5733da99a1b014a487"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acnlvxpbyyy2ib3ihzeesierexia_151.0.7914.0/151.0.7914.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6ac9ee76bf07630a259b6035250ce1ed40fb0caea95ab0ae985d9e78b014d6de"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/dh5ib7b7pcfpx6y4y5q42sr3mq_151.0.7914.0/151.0.7914.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "4ee87b8bee339fb971be768b69f559c8a63260be6d1d6f1cc23b5857f3b4a985"
