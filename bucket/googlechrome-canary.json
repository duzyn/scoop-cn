            "url": "https://dl.google.com/release2/chrome/ol4szxtjo223arv5coroc6sske_147.0.7713.0/147.0.7713.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "73f5bac096d19a7c144cc051c658529147d13bb6521039bf4befb14221a98292"
