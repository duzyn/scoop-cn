            "hash": "ba9139852dde763955d55ae0ff5189e0f8618fd0308bd614c5e7dc1c17ebf7c4"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acxa4aghsjfsxugxaefm3zg7ufgq_149.0.7819.0/149.0.7819.0_chrome_installer_uncompressed.exe#/dl.7z",
