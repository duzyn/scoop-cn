            "hash": "7f93fe5523632c376d7020a3afd9bd9675b1858f780c64373255d5a82fbf131d"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ljxrv5wyygjf4ornnfkw34xj2a_147.0.7717.0/147.0.7717.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "a637b6dd1876fe909d299aecc8bc5e2dc7e79af043ab67cb9d88a177faf590ee"
