            "hash": "6b9e018d47b706155ca3e4dcf87a5eac8c8d1cf7532a1071a1fd88ed18a61a22"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adngs4osx44tu4vusxw5zow43e4a_148.0.7749.0/148.0.7749.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "eeb0cf580a696fa262c2ebc742f8d750c9133fe4455b7846da437ba9030131d3"
