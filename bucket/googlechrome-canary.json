            "hash": "6669add4de188c2572a76386af7a431005cdc154f7e1b2948dfa3ec691c69f98"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ac3nhze6ehraaqtt2cjnnja643hq_148.0.7743.0/148.0.7743.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "53f85d6c464cd34e5e2fe9694a424c622cf810ceaa17842d6b3cd81b8a212c99"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acrq7stb3mliqvd6bz7licr2rhxa_148.0.7743.0/148.0.7743.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "aa97c25b7044cc9adefce5c9c9ef9e74323982d058874ef02cdd67c2662065e5"
