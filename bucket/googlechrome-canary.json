            "hash": "6d7e6f12a5086f1a146a7a3f1274f3d45b812956e6ffb77dda422ad492f6a632"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acshfjzgt7rikoxlwtcj7bctezzq_149.0.7804.0/149.0.7804.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "35f7f9cfd193264f88d4d9260fd6435add6404054919670654a95c9e98ab99f1"
