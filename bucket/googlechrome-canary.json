            "hash": "44896cbf82c864a7c89a0c49442a89e537227dc0ef2ae565786d471060a7e859"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acgc4i3efljgzd27dcwd4dnkrcgq_151.0.7908.0/151.0.7908.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "c070b7b3f96a00c2192de483d04183419aef62241eb0b2e674ae9ada58a620cd"
