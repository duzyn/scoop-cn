        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/adnmaz5r6rd3c267siasxgzithva_149.0.7789.0/149.0.7789.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "9ec46d21b6ff88f2beb53037e5deb136669538b0f3862a350197a4565edba8f0"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/lsytzm4cev5nodkydfsq56s7au_149.0.7789.0/149.0.7789.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d7f815ffc945893e2ac20ebd70ec782832b1c78e487ef7dc4d46301ec798911b"
