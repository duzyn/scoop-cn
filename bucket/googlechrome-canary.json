        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/aczopuhwkv32gxlpfwn6cggwvija_151.0.7875.0/151.0.7875.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "237c0c02a1617d88866a682b0ebc8f005148eedc62ec063a6c050b51b75500b8"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/hkdee6cyxltg5nv4rtzcstjive_151.0.7875.0/151.0.7875.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "e55aebc81746f3c2a737650305fa8b1257020039e8cd6c779e7852d3e89db9b1"
