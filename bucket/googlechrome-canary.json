            "hash": "d901fb31ff01eef204e19d5269bf05c74387b06f10e7a67b610c91e800378778"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ix4562phtb2prvkooownzixxxq_148.0.7741.0/148.0.7741.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "03e808fe53f03c87067e1d69ffd10fa307a02591f7d19dc2171cd2783875066b"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/n52m65fzbsqzwoyd7akfpyolym_148.0.7741.0/148.0.7741.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "20bdf853c74d49e3b14e4cfd3dd8d5411d6704eeea642e51730a20677f0fd7f7"
