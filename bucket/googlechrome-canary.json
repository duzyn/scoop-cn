        "arm64": {
            "url": "https://dl.google.com/release2/chrome/achpanl4uvzariq7ijb4sfsalt3q_148.0.7773.0/148.0.7773.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "8c7f0f6f714b51f5d19feeb2999fc7ad0247f7f057e7e9097a94787a80916222"
