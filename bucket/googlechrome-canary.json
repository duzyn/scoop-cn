        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acgwm7knlem4pxzftmegvcelom6a_148.0.7776.0/148.0.7776.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "0eb9268e7113b284c66bd0fc5023a0270387df5f23303f5acae084ff7c0b5dc8"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/fjdkxccjrkxcpbf5huegiykh4m_148.0.7776.0/148.0.7776.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "12f667f83278d8316dc29c840df9e5d58a7e51db2c5576fd1da99036ae84db0c"
