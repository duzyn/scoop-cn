        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ad2vy5hpz3bol2pfxeqkyg3inofa_151.0.7887.0/151.0.7887.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "8a5ef5c1384e52f3c5429967896300f94c874f21fcbeb67ef3c845a317fe82ea"
