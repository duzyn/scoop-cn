        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/dhvgzyvhkxvnvmekeaiyfwetky_151.0.7904.0/151.0.7904.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d06a612e7a14d7d26143c067a4af94fc89622c5ef606383e447489a79a58c021"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/b3jkvwlqe4cgt36rwhxxtdljsu_151.0.7904.0/151.0.7904.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "3d0e31f2bc4d8acbbad5cc752cf457781c90c8845598a43e6709ad96fad826cc"
