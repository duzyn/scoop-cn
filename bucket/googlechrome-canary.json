        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acq3aq3vj2wynwhaoxtrpcqjh2ba_149.0.7810.0/149.0.7810.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "49bcfa4ff1ae6280922fc992bd59ceda66b8d460bc78cae6463bf6e815f1881a"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ac2imoevj5jmfompk5vr6ilqeg2a_149.0.7810.0/149.0.7810.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "b0c367be9bcead18e7a40ed1de1ce8100eca880ee517c63ea3b24983006a41d1"
