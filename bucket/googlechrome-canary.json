        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acyd2crvy3vm63ocg7sbvx3h5edq_151.0.7881.0/151.0.7881.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "f17375c3e3eb85dd14f4c026436438ea9166dedb9055da83133c1a4f1e1f95cd"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/fcyuenwy6ioqi7kt2iwxkkjwzm_151.0.7881.1/151.0.7881.1_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "322602761965571ab92e0971e3ae34608c524551d6bc9e697f93f947d73174dd"
