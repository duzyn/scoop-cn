        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acbveo5ez6vxa4obhsbdbyw55hka_148.0.7762.0/148.0.7762.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "58330fa64fad40b85d55a9bee38019dc26d21723a2b866a0f13e0db18535379b"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acdbhllqyoucj3tjupc6fj6w5cva_148.0.7763.0/148.0.7763.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "95fb381485905a61c2292d0396f1f8ddbcd69f825f709c4e18a27e45a5cfa0e1"
