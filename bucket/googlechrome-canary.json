            "hash": "cf8340e09c7137db12c3c99fde5c68a51381a4989d0addf721345c736f74bf8a"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ad6frnckluyhmrdeyxyr2snnk6rq_151.0.7885.0/151.0.7885.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "86074e4ea02fdf807955bba3018b23c2fbfcb1e22eaaf975c1f00e7986d7ded0"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adxufsc4koycx6r7poxsyooxydiq_151.0.7885.0/151.0.7885.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "70793a96e05457b909d5e6f7a6c7918c5644a2dbe47d6730e7f3a106db246b06"
