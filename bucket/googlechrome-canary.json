            "hash": "285e755ccffdf5a12a36440e91fdac48221a9a81756d7d8aed5e549b803f45a8"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/bjlnjzfkmdmol2gfjigtq2xgtm_150.0.7863.0/150.0.7863.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "c24f8e3e816b22bed6a74d81b63285b57cc40e31d3330789c2bd739c70b53c8d"
