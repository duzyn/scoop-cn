        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/lt5bghsm5glf35sttom5afh3bq_149.0.7799.0/149.0.7799.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "c650ecae51517d4244fec54311659958084abc7bbf1ea984e8bcb33a9ae0c380"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ad53uzgxczlwavnouq7vjyouheaa_149.0.7799.0/149.0.7799.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "ff6eaff9a325480a0e9b827e4d5f4796d26ad57545c762f4d09b3ae5f6e5452d"
