        "arm64": {
            "url": "https://dl.google.com/release2/chrome/fxctwufhvw5wpvty7cc2mynwsi_148.0.7753.1/148.0.7753.1_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d39d584aec711eff25c34d283812e9bb044a6eb6366f27dc0a56aa31dcc40c71"
