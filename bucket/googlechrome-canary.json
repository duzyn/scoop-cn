            "hash": "887a8de0605461ffe260d35bf7b090cc64f91c61e991e6b307c4b60da6f6ea41"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ol4zhv5rgzmxid2be4pg4clngm_149.0.7779.0/149.0.7779.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "974d17237c61131cefa8e821651590e420332923ec2c77d5b0346b57bc8b0169"
