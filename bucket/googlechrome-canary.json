            "hash": "891feddb7f04a3ef6e8879fcab4be1e5e2c46c75ae16e1b0b2219e155c33aa94"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/aqhsjb6jbzme56f63ijg3ffr6y_150.0.7830.0/150.0.7830.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "fcc5d82ab3148d661879c7ef2797aed92d1146def7b85344a5ef2cf0ec63fc3b"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ack3oiuwbngj7xy4imyoosfgjcra_150.0.7830.0/150.0.7830.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6edcf6da5fb7e47f35f6c5257ca33822eb64e07d1daa1eac1a9a0ca7a8b89a16"
        }
