            "hash": "ae54e102460f321233e8a17b4458fc977f39f35477b9c3aa607bae74c687d5f5"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/aduxw6373ogfg6mblpepwx4z3ola_149.0.7813.0/149.0.7813.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d607f937dbf16d28bce4e6d57c1bcf69d72e5d498c9ebfad0e508072612d5deb"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acw65vnysgslkptdqbezzhr4e2dq_149.0.7813.0/149.0.7813.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "12ba077ebb376238bb23fef2a335ed2b282d3458451414e1e66cf64531b83b19"
