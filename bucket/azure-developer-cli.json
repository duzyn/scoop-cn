{
    "version": "1.25.0",
    "description": "A developer CLI that provides commands for working with Azure resources that map to key workflow stages: code, build, deploy, monitor, repeat.",
    "homepage": "https://aka.ms/azd",
    "license": "MIT",
    "notes": [
        "1. Shell completion requires additional setup, see: https://github.com/Azure/azure-dev",
        "2. Telemetry is enabled by default, it can be disabled by setting env variable \"AZURE_DEV_COLLECT_TELEMETRY\" to \"no\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://gh-proxy.com/https://github.com/Azure/azure-dev/releases/download/azure-dev-cli_1.25.0/azd-windows-amd64.zip",
            "hash": "d64db8652420b266151ffc8a6ab9cd987e8b77ec4f1f1b239c6f5f0485f968bd"
        },
        "arm64": {
            "url": "https://gh-proxy.com/https://github.com/Azure/azure-dev/releases/download/azure-dev-cli_1.25.0/azd-windows-arm64-alpha.zip",
            "hash": "1ae775baffe4914033122a5f20f63a94704a0335db0fecd49580e97f6a6da8af"
        }
    },
    "pre_install": "Get-Item \"$dir\\azd-*.exe\" | Rename-Item -NewName \"azd.exe\"",
    "bin": "azd.exe",
    "post_uninstall": [
        "if ($purge) {",
        "    $Directories = [string[]](",
        "        [System.IO.Path]::Combine($env:USERPROFILE,'.azd')",
        "    )",
        "    $Directories.ForEach{",
        "        if ([System.IO.Directory]::Exists($_)) {",
        "            $null = [System.IO.Directory]::Delete($_,$true)",
        "        }",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/Azure/azure-dev",
        "regex": "azure-dev-cli_([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gh-proxy.com/https://github.com/Azure/azure-dev/releases/download/azure-dev-cli_$version/azd-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://gh-proxy.com/https://github.com/Azure/azure-dev/releases/download/azure-dev-cli_$version/azd-windows-arm64-alpha.zip"
            }
        }
    }
}
